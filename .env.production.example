# ---------------------------------------------------------------------------
# Quest backend — PRODUCTION environment template.
# Copy to `.env` on the production host and fill every [REPLACE] value.
# Never commit the real .env. Back up APP_KEY separately from DB dumps —
# losing it makes every user's encrypted content unrecoverable.
# ---------------------------------------------------------------------------

APP_NAME=Quest
APP_ENV=production
APP_KEY=                       # generate once: `php artisan key:generate --show` — then store it OUTSIDE the DB backups
APP_DEBUG=false                # MUST be false in prod (true leaks stack traces on 500s)
APP_URL=https://thequesting.app             # public HTTPS base; the mobile QUESTING_API_URL points at <APP_URL>/api

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Logging — quieter in prod
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning              # info or warning, never debug

# Database — managed Postgres with daily backups
DB_CONNECTION=pgsql
DB_HOST=REPLACE
DB_PORT=5432
DB_DATABASE=REPLACE
DB_USERNAME=REPLACE
DB_PASSWORD=REPLACE

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=database       # V1 has no queued jobs; revisit + add a worker if that changes
CACHE_STORE=database

# ---------------------------------------------------------------------------
# Binary storage (attachments, audio, character photos) — object storage.
# FILESYSTEM_DISK MUST be s3 in prod so uploads don't land on ephemeral local disk.
# Set AWS_URL to your bucket/CDN HTTPS base so Storage::disk('s3')->url() returns
# https:// URLs (the app rejects non-HTTPS in production).
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=s3
# Cloudflare R2 (S3-compatible). region=auto, path-style=true are R2 requirements.
AWS_ACCESS_KEY_ID=REPLACE-r2-access-key-id
AWS_SECRET_ACCESS_KEY=REPLACE-r2-secret-access-key
AWS_DEFAULT_REGION=auto
AWS_BUCKET=quest-app
AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=https://REPLACE-account-id.r2.cloudflarestorage.com
# PUBLIC download base — the bucket's pub-<hash>.r2.dev domain OR a custom domain.
# NOT the .r2.cloudflarestorage.com S3 API endpoint (that one is private → 400 on
# unauthenticated GET, so clients can't download from it).
AWS_URL=https://pub-be2448a5097447c480bc95e2805ee32d.r2.dev   # r2.dev public URL; swap for a custom domain in real prod

# ---------------------------------------------------------------------------
# OAuth — these MUST match the mobile client, or /api/auth/apple and
# /api/auth/google return 401:
#   APPLE_CLIENT_ID  = the iOS bundle id  -> com.affiniteam.quest  (production build)
#   GOOGLE_CLIENT_ID = the SAME value as the app's QUESTING_GOOGLE_WEB_CLIENT_ID
# ---------------------------------------------------------------------------
APPLE_CLIENT_ID=com.affiniteam.quest
GOOGLE_CLIENT_ID=REPLACE-google-web-client-id.apps.googleusercontent.com
# iOS OAuth client id — also accepted as a valid Google idToken audience.
GOOGLE_IOS_CLIENT_ID=REPLACE-google-ios-client-id.apps.googleusercontent.com

# Sync throttle (requests / minute / user); default is 60
QUEST_RATE_LIMIT_SYNC=60

# Mail — only needed once password reset / email verification (deferred) land
MAIL_MAILER=log

# ---------------------------------------------------------------------------
# Host requirements (NOT env vars — checklist):
#   • Run the Laravel scheduler every minute, e.g. crontab:
#       * * * * * cd /path/to/app && php artisan schedule:run >> /dev/null 2>&1
#     Without it, quest:purge-expired never runs → 30-day retention breaks and
#     soft-deleted rows + their S3 binaries accumulate forever.
#   • Terminate HTTPS upstream (load balancer / reverse proxy); the app assumes it.
#   • Run `php artisan migrate --force` on deploy.
# ---------------------------------------------------------------------------
